{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "test/**/*.ts",
    "tests/**/*.ts",
    "runJSON.ts",
    "global.d.ts",
    "playwright.config.ts"
  ]
}
