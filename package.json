{
  "name": "ts-playwright-upskill",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean:results": "rimraf allure-results",
    "copy:history": "if exist allure-report\\history xcopy allure-report\\history allure-results\\history /E /I /Y",
    "test": "npx playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test-and-report": "npm run clean:results && npm run copy:history && npm run test && npm run allure:generate && npm run allure:open",
    "test:api": "npx playwright test  apiCRUD.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/mssql": "^9.1.8",
    "@types/node": "^24.10.0",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.4.2",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "msnodesqlv8": "^5.1.1",
    "mssql": "^12.1.0"
  }
}
